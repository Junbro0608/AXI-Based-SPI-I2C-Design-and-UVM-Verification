#include "I2C_test.h"

#include "../../driver/Button/button.h"
#include "../../driver/I2C/I2C.h"
#include "../../driver/LED/LED.h"
#include "xil_printf.h"

#define MODE_IDLE  0
#define MODE_WRITE 1
#define MODE_READ  2

hBtn_t hI2C_write, hI2C_raed;

typedef enum I2C_state {
	I2C_IDLE = 0,
	    I2C_ADDR,
	    I2C_WDATA,
	    I2C_RDATA,
	    I2C_STOP
} I2C_state_t;

I2C_state_t I2C_state = IDLE;

void I2C_Init() {
    Button_Init(&hI2C_write, GPIOA, GPIO_PIN_4);
    Button_Init(&hI2C_raed, GPIOA, GPIO_PIN_6);
    LED_Init();
}

void I2C_excute() {
    static uint8_t cnt = 0;
    static uint32_t rdata = 0;
    static int mode = MODE_IDLE;

    xil_printf("s\n");

    switch (I2C_state) {
        case I2C_IDLE:
            if (Button_GetState(&hI2C_write) == ACT_PUSHED) {
                I2C_start(I2C_PORT);
                I2C_state = I2C_ADDR;
                mode = MODE_WRITE;
            } else if (Button_GetState(&hI2C_raed) == ACT_PUSHED) {
                I2C_start(I2C_PORT);
                I2C_state = I2C_ADDR;
                mode = MODE_READ;
            }
            xil_printf("PUSH_BTN\n");
            break;
        case I2C_ADDR:
        	if(mode == MODE_WRITE){
				I2C_Wdata(I2C_PORT, (0x12<<1)+0x00);
				I2C_state = I2C_WDATA;
        	} else{
				I2C_Wdata(I2C_PORT, (0x12<<1)+0x01);
				I2C_state = I2C_RDATA;
        	}
        	xil_printf("ADDR_end W/R=%d\n",mode);
            break;
        case I2C_WDATA:
            I2C_Wdata(I2C_PORT, cnt++);
            I2C_state = STOP;
            xil_printf("Write_end\n");
            break;
        case I2C_RDATA:
            rdata = I2C_Rdata(I2C_PORT);
            I2C_state = STOP;
            xil_printf("Read_end\n");
            break;
        case I2C_STOP:
            I2C_stop(I2C_PORT);
            I2C_state = IDLE;
            xil_printf("STOP_end\n");
            break;
        default:
            break;
    }
    LED_SetComPort(rdata, 1);
}
