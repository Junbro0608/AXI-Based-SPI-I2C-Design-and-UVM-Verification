#include "I2C.h"
#include "xil_printf.h"

void I2C_wait_done(I2C_Typedef_t* I2Cx) {
    while (!(I2Cx->REG3 & DONE));
}
void I2C_wait_busy(I2C_Typedef_t* I2Cx) {
    while ((I2Cx->REG3 & BUSY));
}

void I2C_stop(I2C_Typedef_t* I2Cx) {  // �빊遺쏙옙占쎈쭡
    I2Cx->CR = CMD_STOP;
    I2Cx->CR = DONE_READY;
    I2Cx->CR = 0;
}

void I2C_start(I2C_Typedef_t* I2Cx) {
    I2Cx->CR = CMD_START;
    I2C_wait_busy(I2Cx);
    I2Cx->CR = 0;

    I2C_wait_done(I2Cx);
    I2Cx->CR = DONE_READY;
    I2Cx->CR = 0;
}

void I2C_Wdata(I2C_Typedef_t* I2Cx, uint8_t data) {
    I2Cx->TXD = data;

    I2Cx->CR = CMD_WRITE;
    I2Cx->CR = 0;

//    I2C_wait_done(I2Cx);
    I2Cx->CR = DONE_READY;
    I2Cx->CR = 0;
}

uint32_t I2C_Rdata(I2C_Typedef_t* I2Cx) {
	I2Cx->CR = CMD_READ;
    I2Cx->CR = 0;

	I2C_wait_done(I2Cx);
    I2Cx->CR = DONE_READY;
    I2Cx->CR = 0;
    return I2Cx->RXD;
}

void I2C_Write_Byte(I2C_Typedef_t* I2Cx, uint8_t dev_addr, uint8_t data) {
    I2C_start(I2Cx);

    I2C_Wdata(I2Cx, (dev_addr << 1) & 0xFE);

    I2C_Wdata(I2Cx, data);

    I2C_stop(I2Cx);
}

uint8_t I2C_Read_Byte(I2C_Typedef_t* I2Cx, uint8_t dev_addr) {
    uint8_t data = 0;
    I2C_start(I2Cx);

    I2C_Wdata(I2Cx, (dev_addr << 1) | 0x01);

    data = (uint8_t)I2C_Rdata(I2Cx);

    I2C_stop(I2Cx);

    return data;
}
